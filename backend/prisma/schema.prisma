// Prisma schema for 3rike backend — Midnight privacy-first version.
// Local dev uses SQLite; switch `provider` to "postgresql" for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  role          String   @default("driver") // driver | investor
  // Editable profile fields.
  fullName      String?
  phone         String?
  country       String?
  address       String?
  pinHash       String?  // hashed 4-digit payment PIN

  // Embedded Midnight wallet — auto-created on signup.
  // On Midnight, the "wallet address" is derived from the seed (not a public key).
  walletAddress String   @unique  // Midnight address (derived from seed)
  encryptedKey  String            // AES-256-GCM encrypted Midnight seed

  // KYC commitment hash (on Midnight UserRegistry contract).
  // The raw KYC data never touches the server — only the commitment.
  kycCommitment String?

  createdAt     DateTime @default(now())

  deposits      Deposit[]
  paymentOrders PaymentOrder[]
  investments   Investment[]
}

// Records on/off-chain money movements for history + auditing.
model Deposit {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  kind      String   // crypto | bank
  amountUsdc String  // decimal string (6dp) — private on Midnight
  commitment String? // Midnight ZK commitment hash (replaces txHash for crypto)
  txHash    String?  // Legacy EVM tx hash (for Paycrest bridge only)
  status    String   @default("confirmed") // pending | confirmed | failed
  createdAt DateTime @default(now())
}

// Paycrest treasury-bridge orders (real ₦ <-> real USDC on Arbitrum One).
model PaymentOrder {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  direction  String   // offramp (bank withdrawal) | onramp (bank deposit)
  paycrestId String   @unique
  amountUsdc String   // USDC moved through the treasury
  amountNgn  String?  // fiat leg
  status     String   @default("pending") // pending | settled | refunded | expired | failed
  txHash     String?  // treasury -> Paycrest receiveAddress (offramp funding)
  reference  String?
  createdAt  DateTime @default(now())
}

// Fractional-investment actions — now uses Midnight ZK commitments.
// Ownership + yield are private on Midnight; this is the queryable log.
model Investment {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  tricycleId  Int      // tricycle pool id
  vehicleId   String   // human fleet id (e.g. TRK-001) at time of action
  action      String   // invest | claim
  shares      String?  // shares bought (invest only) — private on Midnight
  amountUsdc  String   // "0" on Midnight (amount is private)
  commitment  String?  // Midnight ZK commitment hash (replaces txHash)
  txHash      String   // commitment hash or legacy tx hash
  createdAt   DateTime @default(now())
}
